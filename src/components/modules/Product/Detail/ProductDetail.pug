section.product-related.section
	.container-seller
		.section-header.text-center.mb-10
			h2.section-title MẪU MÁY LIÊN QUAN
		
		.relative
			.swiper.product-related-swiper
				.swiper-wrapper
					- 
						var relatedProducts = [
							{ cat: 'cat-1', name: 'Máy photocopy Ricoh' },
							{ cat: 'cat-2', name: 'Máy in màu Konica' },
							{ cat: 'cat-3', name: 'Máy sao chụp khổ rộng' },
							{ cat: 'cat-1', name: 'Máy photocopy Ricoh 2' },
							{ cat: 'cat-2', name: 'Máy in màu Konica 2' },
							{ cat: 'cat-3', name: 'Máy sao chụp khổ rộng 2' },
						]
					each item in relatedProducts
						.swiper-slide.h-auto
							+ProductItem(item)
			.swiper-nav-wrapper
				.swiper-button-prev
					i.fa-light.fa-chevron-left
				.swiper-button-next
					i.fa-light.fa-chevron-right