							.swiper-slide
								a(href="./img/pro1.png", data-fancybox="product-gallery")
									.img
										img(src="./img/product-banner.png", alt="")
							.swiper-slide
								a(href="./img/pro1.png", data-fancybox="product-gallery")
									.img
										img(src="./img/pro1.png", alt="")
						.swiper-nav-wrapper
							.swiper-button-prev
								i.fa-light.fa-chevron-left
							.swiper-button-next
								i.fa-light.fa-chevron-right
					.swiper.thumb-swiper
