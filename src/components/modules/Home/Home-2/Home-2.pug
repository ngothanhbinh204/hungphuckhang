							.nation(class="heading-3 font-semibold") Asia
						.right(class="grid grid-cols-3 rem:gap-[10px] flex-1 w-full")
							-for(var i = 0; i < 3; i++)
								.wrap-nation
									.nation-item(class="flex items-center gap-1")
										.icon 
											<i class="fa-solid fa-chevrons-right"></i>
										.name-nation(class="font-secondary") Japan
									.nation-item(class="flex items-center gap-1")
