section.home-4(class="section-py" setBackground="./img/bg-home-4.png")
	.container-fluid 
		.wrapper(class="grid xl:grid-cols-2 grid-cols-1 rem:gap-[42px] items-center")
			.col-left 
				.sub-title(class="heading-4 font-semibold uppercase mb-3") CORE PRODUCTION SYSTEM
				h2.title(class="heading-1 block-title") Advanced technology – the foundation of superior quality
			.col-right 
				.lists(class="grid lg:grid-cols-3 grid-cols-2 xl:gap-0 gap-base")
					-for(var i = 0; i < 3; i++)
						.item 
							.title(class="py-10 px-6 heading-3 font-semibold") 
								a(href="#") Calcined Dolomite Kiln Technology
							.button-more(class="inline-flex justify-end")
								a(href="#") 
									<i class="fa-light fa-arrow-right-long"></i>